<Window x:Class="RadioApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Интернет Радио" 
        Height="300" 
        Width="500"
        WindowStartupLocation="CenterScreen">
    
<Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
</Window.Resources>
    <StackPanel Margin="20">
        
        <TextBlock Text="🎵 Интернет Радио" 
                   FontSize="24" 
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>
        
        <!-- Поле для ввода ссылки -->
        <TextBlock Text="Введите ссылку на радиостанцию:" 
                   Margin="0,0,0,5"
                   FontSize="14"/>
        
        <TextBox x:Name="UrlTextBox" 
                 Height="35" 
                 Margin="0,0,0,15"
                 FontSize="12"
                 Padding="5"/>
        
        <!-- Кнопки -->
        <Button x:Name="PlayButton" 
                Content="▶ Воспроизвести" 
                Background="#4CAF50"
                Style="{StaticResource BaseButtonStyle}"/>

        
        <Button x:Name="StopButton" 
                Content="⏹ Остановить" 
                Background="#F44336"
                Style="{StaticResource BaseButtonStyle}"/>
        
        <!-- Статус -->
        <TextBlock x:Name="StatusText" 
                   Text="Статус: Готов" 
                   FontSize="12"
                   HorizontalAlignment="Center"
                   Margin="0,15,0,0"
                   Foreground="#666666"/>
        
        <!-- Подсказка -->
        <TextBlock Text="Примеры ссылок: http://cdn.energyfm.ru:9000/energy" 
                   FontSize="10"
                   Foreground="#999999"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,0"
                   TextWrapping="Wrap"/>
    </StackPanel>
</Window>